{
    "files.associations": {
        "*.cpp": "cpp"
    },
    "editor.minimap": {
        "enabled": false
    },
    "editor.renderWhitespace": "boundary",
    "editor.fontSize": 14,
    "workbench.colorTheme": "Default Dark+",
    "C_Cpp.errorSquiggles": "enabled",
    "C_Cpp.default.intelliSenseMode": "windows-gcc-x64",
    "C_Cpp.default.compilerPath": "g++"
}
